# Copy to .env for docker-compose.prod.yml (never commit real secrets)

# --- Infrastructure ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kids_edu
HTTP_PORT=80
RUN_MIGRATIONS=true

# --- Public URLs (nginx) ---
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost/api/v1
CORS_ORIGIN=http://localhost

# --- API ---
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1
TRUST_PROXY=true
SWAGGER_ENABLED=false
METRICS_ENABLED=true
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/kids_edu?schema=public

JWT_ACCESS_SECRET=replace-with-64-char-random-access-secret-minimum-length-32
JWT_REFRESH_SECRET=replace-with-64-char-random-refresh-secret-minimum-length-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ACCESS_TOKEN_COOKIE=access_token
REFRESH_TOKEN_COOKIE=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=yourdomain.com

BCRYPT_ROUNDS=12

REDIS_URL=redis://redis:6379
REDIS_ENABLED=true
CACHE_TTL_SECONDS=300

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# --- OpenAI (cost control) ---
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
AI_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_HOUR=30

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
SWAGGER_ENABLED=true
METRICS_ENABLED=false
LOG_LEVEL=info

# Redis / cache
REDIS_URL=redis://localhost:6379
# false = no Redis required for local dev; true when using docker compose redis
REDIS_ENABLED=false
CACHE_TTL_SECONDS=300

# Global rate limit (NestJS Throttler)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kids_edu?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth cookies
ACCESS_TOKEN_COOKIE=access_token
REFRESH_TOKEN_COOKIE=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=localhost

# Bcrypt
BCRYPT_ROUNDS=12

# Learning flow
LEARNING_UNLOCK_SCORE=85

# Testing engine
TEST_QUESTION_COUNT=5
TEST_CHOICES_PER_QUESTION=4
TEST_MAX_ATTEMPTS=3
TEST_TIME_LIMIT_MINUTES=15
TEST_MAX_TAB_BLURS=5
TEST_MAX_PASTE=0

# Analytics
ANALYTICS_WEAK_SCORE=70
ANALYTICS_DIFFICULT_TOPIC_SCORE=75
ANALYTICS_PROGRESS_DAYS=30

# OpenAI / AI module
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_BASE_DELAY_MS=1000
OPENAI_TIMEOUT_MS=30000
AI_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_HOUR=30
